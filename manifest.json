{
  "manifest_version": 3,
  "name": "BGG Rank Enricher",
  "version": "0.1.0",
  "description": "Displays BoardGameGeek rankings on board game shop pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.boardgamegeek.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.philibertnet.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {},
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
